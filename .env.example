# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL 15) ────────────────────────────────
DATABASE_URL=postgresql://keyvaultx_user:your_password@localhost:5432/keyvaultx
POSTGRES_DB=keyvaultx
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ─── Redis (Rate Limiting & Caching) ────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── Security — JWT ─────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_SECURE_RANDOM_STRING

# ─── Security — Encryption (AES-256-GCM) ────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=CHANGE_ME_TO_64_HEX_CHARS
# Alias (either works):
# KEK_KEY=CHANGE_ME_TO_64_HEX_CHARS

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Billing Tiers (defaults baked into schema) ─────────────
# FREE tier:  maxSecrets=100, maxIdentities=5
# PRO tier:   maxSecrets=1000, maxIdentities=50
# ENTERPRISE: maxSecrets=unlimited, maxIdentities=unlimited
# Configured per-tenant in the database, not via env vars.
